			<signature>signal session_started(mode: int, endpoint: String)</signature>
			<description>会话开始时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">mode: Mode 枚举值。</tag>
				<tag name="param">endpoint: 会话端点。</tag>
			</tags>
		</member>
		<member kind="signal" name="session_connected">
			<signature>signal session_connected(local_peer_id: int)</signature>
			<description>会话连接成功时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">local_peer_id: 本地 peer 标识。</tag>
			</tags>
		</member>
		<member kind="signal" name="session_closed">
			<signature>signal session_closed(reason: String)</signature>
