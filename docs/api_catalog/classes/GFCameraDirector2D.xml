			<signature>signal active_rig_changed(previous_rig: GFCameraRig2D, new_rig: GFCameraRig2D)</signature>
			<description>当前 Rig 变化后发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">previous_rig: 上一个 Rig。</tag>
				<tag name="param">new_rig: 新 Rig。</tag>
			</tags>
		</member>
		<member kind="signal" name="camera_pose_applied">
			<signature>signal camera_pose_applied(rig: GFCameraRig2D)</signature>
			<description>相机姿态应用后发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">rig: 当前 Rig。</tag>
			</tags>
		</member>
	</signals>
