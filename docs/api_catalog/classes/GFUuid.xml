		<member kind="const" name="BYTE_COUNT">
			<signature>const BYTE_COUNT: int = 16</signature>
			<description>UUID 字节长度。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="const" name="CANONICAL_LENGTH">
			<signature>const CANONICAL_LENGTH: int = 36</signature>
			<description>UUID 规范字符串长度。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</constants>
	<properties />
