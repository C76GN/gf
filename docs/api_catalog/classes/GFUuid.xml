			<signature>static func generate_v4() -&gt; String:</signature>
			<description>生成随机 UUID v4。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">小写 canonical UUID 字符串。</tag>
			</tags>
		</member>
		<member kind="method" name="generate_v7">
			<signature>static func generate_v7(unix_time_msec: int = -1) -&gt; String:</signature>
			<description>生成时间有序 UUID v7。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">unix_time_msec: Unix epoch 毫秒；小于 0 时使用系统当前时间。</tag>
				<tag name="return">小写 canonical UUID 字符串。</tag>
			</tags>
		</member>
		<member kind="method" name="is_valid">
			<signature>static func is_valid(value: String, version: int = 0) -&gt; bool:</signature>
			<description>判断字符串是否为 canonical UUID。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">value: 待校验字符串。</tag>
				<tag name="param">version: 可选版本过滤；0 表示接受任意版本。</tag>
				<tag name="return">字符串符合 canonical UUID 形态且版本匹配时返回 true。</tag>
			</tags>
		</member>
