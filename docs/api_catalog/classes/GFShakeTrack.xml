			<signature>var amplitude: float = 1.0</signature>
			<description>轨道振幅倍率。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="frequency" decorators="@export_range(0.0, 240.0, 0.001, &quot;or_greater&quot;)">
			<signature>var frequency: float = 24.0</signature>
