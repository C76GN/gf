				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="blend_mode" decorators="@export">
			<signature>var blend_mode: BlendMode = BlendMode.ADD</signature>
			<description>轨道混合模式。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="waveform" decorators="@export">
			<signature>var waveform: Waveform = Waveform.NOISE</signature>
			<description>轨道采样波形。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="start_progress" decorators="@export_range(0.0, 1.0, 0.001)">
			<signature>var start_progress: float = 0.0</signature>
			<description>轨道开始进度，范围 0 到 1。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="end_progress" decorators="@export_range(0.0, 1.0, 0.001)">
			<signature>var end_progress: float = 1.0</signature>
			<description>轨道结束进度，范围 0 到 1。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
