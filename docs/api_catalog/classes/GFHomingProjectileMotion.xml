			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="target_position_context_key" decorators="@export">
			<signature>var target_position_context_key: StringName = &amp;"target_position"</signature>
			<description>从 projectile_context 读取通用目标位置的键。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="arrival_distance" decorators="@export">
			<signature>var arrival_distance: float = 0.0</signature>
			<description>到目标的距离小于等于该值时视为到达。小于 0 表示不标记到达。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
