或 target_position_3d 传入，也可以用 target_path 从发射体节点相对查找。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">resource_definition</tag>
		<tag name="since">3.17.0</tag>
	</tags>
	<signals />
	<enums />
	<constants />
	<properties>
		<member kind="property" name="speed" decorators="@export">
