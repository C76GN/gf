<class name="GFAnalyticsUtility" path="addons/gf/standard/utilities/analytics/gf_analytics_utility.gd" module="standard" extends="GFUtility" classDigest="81920ebd58ba800e6c15635bc29852a3200afce41811248f182d625c7a789cf8">
	<description>GFAnalyticsUtility: 通用事件分析与批量上报工具。
负责事件排队、环境上下文采集、批量 flush 与失败重排。
endpoint 为空时不会访问网络，可作为本地事件汇聚或测试通道使用。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">runtime_service</tag>
		<tag name="since">3.17.0</tag>
	</tags>
	<signals>
		<member kind="signal" name="event_tracked">
			<signature>signal event_tracked(event_name: StringName, event_data: Dictionary)</signature>
			<description>事件进入队列时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">event_name: 事件名。</tag>
				<tag name="param">event_data: 已入队事件数据。</tag>
				<tag name="schema">event_data: Dictionary with `event`, `client_id`, `session_id`, `timestamp`, `properties`, and optional `context`.</tag>
			</tags>
		</member>
		<member kind="signal" name="flush_started">
			<signature>signal flush_started(batch: Array)</signature>
			<description>开始 flush 时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">batch: 本次 flush 的事件批次。</tag>
				<tag name="schema">batch: Array[Dictionary] of queued analytics events.</tag>
			</tags>
		</member>
		<member kind="signal" name="flush_completed">
			<signature>signal flush_completed(result: Dictionary)</signature>
			<description>flush 完成时发出。失败结果也会通过该信号通知。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">result: flush 结果。</tag>
				<tag name="schema">result: Dictionary with at least `success: bool`; may include `accepted`, `error`, `dry_run`, or transport-specific fields.</tag>
			</tags>
		</member>
		<member kind="signal" name="flush_failed">
			<signature>signal flush_failed(result: Dictionary)</signature>
			<description>flush 失败时额外发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">result: 失败结果。</tag>
				<tag name="schema">result: Dictionary with `success: false` and an optional `error` field.</tag>
			</tags>
		</member>
	</signals>
