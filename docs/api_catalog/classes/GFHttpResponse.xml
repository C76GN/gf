<?xml version="1.0" encoding="utf-8"?>
<class name="GFHttpResponse" path="addons/gf/standard/utilities/io/gf_http_response.gd" module="standard" extends="RefCounted" classDigest="b4f695b71c8a5c2592a55020d1ec4b537b7a11a1ee70817a4da9ac13b836fc4f">
	<description>GFHttpResponse: 通用 HTTP 请求结果。
以对象形式表达 pending、completed、failed、cancelled 等状态，便于请求构建器、
批处理器和项目侧工具统一观察异步结果。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">runtime_handle</tag>
		<tag name="since">3.17.0</tag>
	</tags>
	<signals>
		<member kind="signal" name="completed">
			<signature>signal completed(response: GFHttpResponse)</signature>
			<description>响应完成、失败或取消时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">response: 当前响应对象。</tag>
			</tags>
		</member>
	</signals>
	<enums>
		<member kind="enum" name="State">
			<signature>enum State { ## 请求仍在等待完成。 PENDING, ## 请求成功完成。 COMPLETED, ## 请求失败。 FAILED, ## 请求被取消。 CANCELLED, }</signature>
			<description>HTTP 响应句柄状态。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</enums>
	<constants />
	<properties>
		<member kind="property" name="state">
			<signature>var state: State = State.PENDING</signature>
			<description>响应状态。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="url">
			<signature>var url: String = ""</signature>
			<description>原始 URL。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="status_code">
			<signature>var status_code: int = 0</signature>
			<description>HTTP 状态码。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="result_code">
			<signature>var result_code: int = HTTPRequest.RESULT_SUCCESS</signature>
			<description>Godot HTTPRequest 结果码。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="headers">
			<signature>var headers: PackedStringArray = PackedStringArray()</signature>
			<description>响应头。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="text">
			<signature>var text: String = ""</signature>
			<description>响应文本。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="body">
			<signature>var body: PackedByteArray = PackedByteArray()</signature>
			<description>响应原始 bytes。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="data">
			<signature>var data: Variant = null</signature>
			<description>解析后的数据，例如 JSON 结果。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="schema">data: Variant，解析后的响应载荷，例如 JSON 数据、文本数据或 null。</tag>
			</tags>
		</member>
		<member kind="property" name="error">
			<signature>var error: String = ""</signature>
			<description>错误说明。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="metadata">
			<signature>var metadata: Dictionary = {}</signature>
			<description>调用方附加元数据。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="schema">metadata: Dictionary，从请求构建器复制的调用方元数据。</tag>
			</tags>
		</member>
		<member kind="property" name="cancel_callback">
			<signature>var cancel_callback: Callable = Callable()</signature>
			<description>取消请求时执行的底层取消回调。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</properties>
	<methods>
		<member kind="method" name="is_pending">
			<signature>func is_pending() -&gt; bool:</signature>
			<description>请求是否仍在等待。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">仍在等待时返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="is_successful">
			<signature>func is_successful() -&gt; bool:</signature>
			<description>请求是否成功。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">请求以 2xx HTTP 状态码完成且没有错误时返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="is_finished">
			<signature>func is_finished() -&gt; bool:</signature>
			<description>请求是否已结束。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">请求完成、失败或取消时返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="get_header">
			<signature>func get_header(header_name: String, default_value: String = "") -&gt; String:</signature>
			<description>读取第一个匹配的响应头。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">header_name: 响应头名称，按大小写不敏感方式匹配。</tag>
				<tag name="param">default_value: 没有匹配响应头时返回的默认值。</tag>
				<tag name="return">响应头值；没有匹配项时返回 default_value。</tag>
			</tags>
		</member>
		<member kind="method" name="get_header_values">
			<signature>func get_header_values(header_name: String) -&gt; PackedStringArray:</signature>
			<description>读取所有匹配的响应头值。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">header_name: 响应头名称，按大小写不敏感方式匹配。</tag>
				<tag name="return">匹配的响应头值列表，保留原始出现顺序。</tag>
			</tags>
		</member>
		<member kind="method" name="get_headers_dictionary">
			<signature>func get_headers_dictionary() -&gt; Dictionary:</signature>
			<description>生成大小写规范化的响应头字典。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">响应头字典。</tag>
				<tag name="schema">return: Dictionary，键为小写 header 名称，值为 PackedStringArray，重复响应头会按出现顺序保留。</tag>
			</tags>
		</member>
		<member kind="method" name="complete_success">
			<signature>func complete_success(fields: Dictionary = {}) -&gt; void:</signature>
			<description>标记请求成功完成。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">fields: 需要写入响应对象的字段。</tag>
				<tag name="schema">fields: Dictionary，可包含 url、status_code、result_code、headers、text、body、data 和 metadata。</tag>
			</tags>
		</member>
		<member kind="method" name="complete_failure">
			<signature>func complete_failure(message: String, fields: Dictionary = {}) -&gt; void:</signature>
			<description>标记请求失败。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">message: 错误说明。</tag>
				<tag name="param">fields: 需要写入响应对象的字段。</tag>
				<tag name="schema">fields: Dictionary，可包含 url、status_code、result_code、headers、text、body、data 和 metadata。</tag>
			</tags>
		</member>
		<member kind="method" name="cancel">
			<signature>func cancel(reason: String = "cancelled") -&gt; void:</signature>
			<description>取消请求。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">reason: 取消原因。</tag>
			</tags>
		</member>
		<member kind="method" name="to_dictionary">
			<signature>func to_dictionary() -&gt; Dictionary:</signature>
			<description>转为普通字典。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">响应快照。</tag>
				<tag name="schema">return: Dictionary，包含响应状态、URL、HTTP 状态、解析数据、错误信息和 metadata。</tag>
			</tags>
		</member>
	</methods>
	<innerClasses />
</class>
