				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="to_alpha" decorators="@export_range(0.0, 1.0, 0.001)">
			<signature>var to_alpha: float = 1.0</signature>
			<description>结束透明度。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="color" decorators="@export">
