			<signature>signal step_failed(index: int, step: Variant, error: String)</signature>
			<description>步骤报告失败时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">index: 步骤索引。</tag>
				<tag name="param">step: 步骤对象、命令或 Callable。</tag>
