			</tags>
		</member>
		<member kind="signal" name="step_started">
			<signature>signal step_started(index: int, step: Variant)</signature>
			<description>步骤开始执行时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">index: 步骤索引。</tag>
				<tag name="param">step: 步骤对象、命令或 Callable。</tag>
				<tag name="schema">step: Variant sequence step value.</tag>
			</tags>
		</member>
