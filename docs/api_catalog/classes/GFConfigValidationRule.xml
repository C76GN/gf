<?xml version="1.0" encoding="utf-8"?>
<class name="GFConfigValidationRule" path="addons/gf/standard/utilities/config/validation/gf_config_validation_rule.gd" module="standard" extends="Resource" classDigest="4095ecb5d61ebaf2fc44c2490ce93309978b6730327d777b4f1f40d4f63f57dd">
	<description>GFConfigValidationRule: 导表校验规则基类。
用于把字段、记录或整表校验拆成可组合 Resource，便于项目按需声明范围、
正则、资源路径或本地化 key 等规则，而不把业务表结构写进框架。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">protocol</tag>
		<tag name="since">3.17.0</tag>
	</tags>
	<signals />
	<enums>
		<member kind="enum" name="IssueSeverity">
			<signature>enum IssueSeverity { ## 警告，不阻止报告通过。 WARNING, ## 错误，会让报告失败。 ERROR, }</signature>
			<description>校验问题严重级别。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</enums>
	<constants />
	<properties>
		<member kind="property" name="rule_id" decorators="@export">
			<signature>var rule_id: StringName = &amp;""</signature>
			<description>规则稳定标识。为空时使用规则类型默认标识。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="enabled" decorators="@export">
			<signature>var enabled: bool = true</signature>
			<description>是否启用当前规则。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="severity" decorators="@export">
			<signature>var severity: IssueSeverity = IssueSeverity.ERROR</signature>
			<description>规则触发时写入报告的严重级别。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="allow_null" decorators="@export">
			<signature>var allow_null: bool = true</signature>
			<description>值为 null 时是否直接跳过值校验。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="metadata" decorators="@export">
			<signature>var metadata: Dictionary = {}</signature>
			<description>可选元数据，供编辑器或项目工具扩展使用。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="schema">metadata: Dictionary，保存编辑器或项目层附加到当前规则的元数据。</tag>
			</tags>
		</member>
	</properties>
	<methods>
		<member kind="method" name="get_rule_id">
			<signature>func get_rule_id() -&gt; StringName:</signature>
			<description>获取稳定规则标识。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">规则标识。</tag>
			</tags>
		</member>
		<member kind="method" name="validate_value">
			<signature>func validate_value(value: Variant, context: Dictionary = {}) -&gt; Dictionary:</signature>
			<description>校验单个字段值。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">value: 待校验值。</tag>
				<tag name="param">context: 可选上下文，支持 table_name、row_key、field、source、line、column。</tag>
				<tag name="return">校验报告字典。</tag>
				<tag name="schema">value: Variant，来自配置表或项目导入器的字段值。</tag>
				<tag name="schema">context: Dictionary，可包含 table_name、row_key、field、source、line 和 column 字段。</tag>
				<tag name="schema">return: GFConfigValidationReport 兼容 Dictionary。</tag>
			</tags>
		</member>
		<member kind="method" name="validate_record">
			<signature>func validate_record(record: Dictionary, context: Dictionary = {}) -&gt; Dictionary:</signature>
			<description>校验单条记录。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">record: 待校验记录。</tag>
				<tag name="param">context: 可选上下文，支持 table_name、row_key、source、line。</tag>
				<tag name="return">校验报告字典。</tag>
				<tag name="schema">record: Dictionary，正在校验的配置记录。</tag>
				<tag name="schema">context: Dictionary，可包含 table_name、row_key、source 和 line 字段。</tag>
				<tag name="schema">return: GFConfigValidationReport 兼容 Dictionary。</tag>
			</tags>
		</member>
		<member kind="method" name="validate_table">
			<signature>func validate_table(rows: Array[Dictionary], context: Dictionary = {}) -&gt; Dictionary:</signature>
			<description>校验整张表。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">rows: 规范化行列表，每项通常包含 row_key、record 和 row_index。</tag>
				<tag name="param">context: 可选上下文，支持 table_name、source。</tag>
				<tag name="return">校验报告字典。</tag>
				<tag name="schema">rows: Array[Dictionary]，元素通常包含 row_key、record 和 row_index。</tag>
				<tag name="schema">context: Dictionary，可包含 table_name 和 source 字段。</tag>
				<tag name="schema">return: GFConfigValidationReport 兼容 Dictionary。</tag>
			</tags>
		</member>
		<member kind="method" name="duplicate_rule">
			<signature>func duplicate_rule() -&gt; GFConfigValidationRule:</signature>
			<description>创建同内容拷贝。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">新规则。</tag>
			</tags>
		</member>
		<member kind="method" name="describe">
			<signature>func describe() -&gt; Dictionary:</signature>
			<description>导出规则摘要。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">规则摘要字典。</tag>
				<tag name="schema">return: Dictionary，包含 rule_id、enabled、severity、allow_null、metadata 和 script_path。</tag>
			</tags>
		</member>
	</methods>
	<innerClasses />
</class>
