			<tags>
				<tag name="api">public</tag>
				<tag name="param">serializer: 序列化器。</tag>
			</tags>
		</member>
		<member kind="method" name="unregister_serializer">
			<signature>func unregister_serializer(serializer_id: StringName) -&gt; void:</signature>
