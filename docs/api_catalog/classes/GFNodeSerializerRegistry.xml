		<member kind="method" name="clear">
			<signature>func clear() -&gt; void:</signature>
			<description>清空注册表。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="get_serializer">
			<signature>func get_serializer(serializer_id: StringName) -&gt; GFNodeSerializer:</signature>
			<description>获取指定序列化器。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">serializer_id: 序列化器标识。</tag>
				<tag name="return">序列化器实例。</tag>
			</tags>
		</member>
		<member kind="method" name="get_serializers_for_node">
			<signature>func get_serializers_for_node(node: Node) -&gt; Array[GFNodeSerializer]:</signature>
			<description>获取所有支持指定节点的序列化器。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">node: 目标节点。</tag>
