<?xml version="1.0" encoding="utf-8"?>
<class name="GFQuestUtility" path="addons/gf/extensions/domain/quest/gf_quest_utility.gd" module="extensions/domain" extends="GFUtility" classDigest="970383865bf5ef9ffbdbd9d5ecaef78b3b35ac274c2c9ab816edac71d28ba9b2">
	<description>GFQuestUtility: 轻量级任务进度监听系统。
基于 `simple event` 将业务事件映射为任务进度累积，
适合用于成就、收集与击杀类目标的低成本跟踪。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">runtime_service</tag>
		<tag name="since">3.17.0</tag>
	</tags>
	<signals>
		<member kind="signal" name="quest_started">
			<signature>signal quest_started(quest_id: StringName)</signature>
			<description>当任务开始监听时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_available">
			<signature>signal quest_available(quest_id: StringName)</signature>
			<description>当任务进入可接取状态时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_acceptance_blocked">
			<signature>signal quest_acceptance_blocked(quest_id: StringName, reason: String)</signature>
			<description>当任务接取条件拒绝时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">reason: 拒绝原因。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_progressed">
			<signature>signal quest_progressed(quest_id: StringName, current: int, target: int)</signature>
			<description>当任务进度变化时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">current: 当前进度。</tag>
				<tag name="param">target: 目标进度。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_completed">
			<signature>signal quest_completed(quest_id: StringName)</signature>
			<description>当任务完成时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 完成的任务 ID。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_completion_blocked">
			<signature>signal quest_completion_blocked(quest_id: StringName, reason: String)</signature>
			<description>当任务完成条件被阻塞器拒绝时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">reason: 阻塞原因。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_cancelled">
			<signature>signal quest_cancelled(quest_id: StringName)</signature>
			<description>当任务取消时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
		<member kind="signal" name="quest_failed">
			<signature>signal quest_failed(quest_id: StringName)</signature>
			<description>当任务失败时发出。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
	</signals>
