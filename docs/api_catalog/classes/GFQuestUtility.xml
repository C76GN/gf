			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="const" name="STATUS_COMPLETED">
			<signature>const STATUS_COMPLETED: StringName = &amp;"completed"</signature>
			<description>任务已完成。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
