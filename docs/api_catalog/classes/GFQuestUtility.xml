	<properties>
		<member kind="property" name="allow_negative_progress">
			<signature>var allow_negative_progress: bool = false</signature>
			<description>是否允许事件传入负数进度。默认关闭，避免任务进度被异常 payload 反向扣减。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</properties>
	<methods>
		<member kind="method" name="start_quest">
			<signature>func start_quest(quest_id: StringName, target_event: StringName, target_count: int = 1) -&gt; void:</signature>
			<description>开始监听一个任务。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">target_event: 推进该任务的事件 ID。</tag>
				<tag name="param">target_count: 完成任务所需的累计次数。</tag>
			</tags>
		</member>
		<member kind="method" name="define_quest">
			<signature>func define_quest( quest_id: StringName, target_event: StringName, target_count: int = 1, metadata: Dictionary = {} ) -&gt; void:</signature>
			<description>定义一个可接取任务，但暂不开始监听事件。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">target_event: 推进该任务的事件 ID。</tag>
				<tag name="param">target_count: 完成任务所需的累计次数。</tag>
				<tag name="param">metadata: 任务元数据。框架不解释该字段。</tag>
				<tag name="schema">metadata: Dictionary，项目自定义任务元数据；GF 会复制保存并在任务报告中透传。</tag>
			</tags>
		</member>
		<member kind="method" name="accept_quest">
			<signature>func accept_quest(quest_id: StringName) -&gt; bool:</signature>
			<description>接取一个已定义任务，并开始监听事件。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">接取成功返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="complete_quest">
			<signature>func complete_quest(quest_id: StringName) -&gt; bool:</signature>
			<description>手动完成一个任务。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">完成成功返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="cancel_quest">
			<signature>func cancel_quest(quest_id: StringName) -&gt; bool:</signature>
			<description>取消一个任务。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">取消成功返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="fail_quest">
			<signature>func fail_quest(quest_id: StringName, reason: String = "") -&gt; bool:</signature>
			<description>标记任务失败。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">reason: 可选失败原因，会写入任务 metadata 的 last_failure_reason。</tag>
				<tag name="return">标记成功返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="add_acceptance_condition">
			<signature>func add_acceptance_condition(quest_id: StringName, condition: Callable) -&gt; void:</signature>
			<description>添加接取条件。条件返回 false 或包含 ok=false 的 Dictionary 时阻止接取。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">condition: 条件回调。</tag>
			</tags>
		</member>
		<member kind="method" name="clear_acceptance_conditions">
			<signature>func clear_acceptance_conditions(quest_id: StringName) -&gt; void:</signature>
			<description>清空任务接取条件。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
		<member kind="method" name="add_completion_blocker">
			<signature>func add_completion_blocker(quest_id: StringName, blocker: Callable) -&gt; void:</signature>
			<description>添加完成阻塞器。阻塞器返回 false 或包含 ok=false 的 Dictionary 时阻止完成。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="param">blocker: 阻塞器回调。</tag>
			</tags>
		</member>
		<member kind="method" name="clear_completion_blockers">
			<signature>func clear_completion_blockers(quest_id: StringName) -&gt; void:</signature>
			<description>清空任务完成阻塞器。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
		<member kind="method" name="set_quest_parent">
			<signature>func set_quest_parent(quest_id: StringName, parent_quest_id: StringName) -&gt; bool:</signature>
			<description>设置任务父级关系。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 子任务 ID。</tag>
				<tag name="param">parent_quest_id: 父任务 ID。</tag>
				<tag name="return">设置成功返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="clear_quest_parent">
			<signature>func clear_quest_parent(quest_id: StringName) -&gt; void:</signature>
			<description>清除任务父级关系。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
			</tags>
		</member>
		<member kind="method" name="get_child_quests">
			<signature>func get_child_quests(quest_id: StringName) -&gt; PackedStringArray:</signature>
			<description>获取任务的直接子任务 ID。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">子任务 ID 列表。</tag>
			</tags>
		</member>
		<member kind="method" name="get_quest_tree_report">
			<signature>func get_quest_tree_report(root_quest_id: StringName) -&gt; Dictionary:</signature>
			<description>获取任务树报告。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">root_quest_id: 根任务 ID。</tag>
				<tag name="return">树形报告；任务不存在时返回空字典。</tag>
				<tag name="schema">return: Dictionary，包含任务报告字段、children: Array[Dictionary]、total_count、completed_count 与 aggregate_progress。</tag>
			</tags>
		</member>
		<member kind="method" name="emit_quest_event">
			<signature>func emit_quest_event(event_id: StringName, amount: int = 1) -&gt; void:</signature>
			<description>手动触发一次任务事件。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">event_id: 事件 ID。</tag>
				<tag name="param">amount: 本次增加的进度值。</tag>
			</tags>
		</member>
		<member kind="method" name="is_quest_completed">
			<signature>func is_quest_completed(quest_id: StringName) -&gt; bool:</signature>
			<description>查询任务是否已经完成。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">已完成时返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="get_quest_progress">
			<signature>func get_quest_progress(quest_id: StringName) -&gt; float:</signature>
			<description>获取任务进度百分比。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">范围在 0.0 到 1.0 之间的进度值。</tag>
			</tags>
		</member>
		<member kind="method" name="get_quest_status">
			<signature>func get_quest_status(quest_id: StringName) -&gt; StringName:</signature>
			<description>获取任务状态。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">状态文本。</tag>
			</tags>
		</member>
		<member kind="method" name="get_quests_by_status">
			<signature>func get_quests_by_status(status: StringName) -&gt; PackedStringArray:</signature>
			<description>获取指定状态的任务 ID。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">status: 任务状态。</tag>
				<tag name="return">任务 ID 列表。</tag>
			</tags>
		</member>
		<member kind="method" name="get_quest_report">
			<signature>func get_quest_report(quest_id: StringName) -&gt; Dictionary:</signature>
			<description>获取任务报告。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">quest_id: 任务 ID。</tag>
				<tag name="return">任务报告字典。</tag>
				<tag name="schema">return: Dictionary，包含 quest_id、event_id、target_count、current_count、is_completed、status、parent_id、child_ids、metadata、acceptance_condition_count 与 completion_blocker_count。</tag>
			</tags>
		</member>
		<member kind="method" name="get_debug_snapshot">
			<signature>func get_debug_snapshot() -&gt; Dictionary:</signature>
			<description>获取任务系统调试快照。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">调试快照字典。</tag>
				<tag name="schema">return: Dictionary，包含 quest_count、event_count 与 quests；quests 键为 String 任务 ID，值为任务报告字典。</tag>
			</tags>
		</member>
