<?xml version="1.0" encoding="utf-8"?>
<class name="GFRepeatAction" path="addons/gf/extensions/action_queue/actions/gf_repeat_action.gd" module="extensions/action_queue" extends="GFVisualAction" classDigest="a94a27702cade97a4ce77fa26d3fa56b2806df7b9379ff48492ea0bdc2fdb7ef">
	<description>GFRepeatAction: 按工厂重复创建并执行队列动作。
每轮通过 action_factory 创建一个新的动作对象，避免复用同一个动作实例时
残留 Tween、Timer 或节点引用状态。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">runtime_handle</tag>
		<tag name="since">3.17.0</tag>
	</tags>
	<signals>
		<member kind="signal" name="repeat_completed">
			<signature>signal repeat_completed</signature>
			<description>重复流程结束时发出。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</signals>
	<enums />
	<constants>
		<member kind="const" name="DEFAULT_MAX_IMMEDIATE_ITERATIONS_PER_FRAME">
			<signature>const DEFAULT_MAX_IMMEDIATE_ITERATIONS_PER_FRAME: int = 256</signature>
			<description>单帧最多连续执行的瞬时重复次数，避免无限重复的瞬时动作锁住主线程。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</constants>
	<properties>
		<member kind="property" name="action_factory">
			<signature>var action_factory: Callable</signature>
			<description>动作工厂。每次调用应返回一个动作对象；返回 null 会结束重复。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="repeat_count">
			<signature>var repeat_count: int = 1</signature>
			<description>重复次数。0 表示无限重复，直到 cancel()、finish() 或工厂返回 null。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="max_immediate_iterations_per_frame">
			<signature>var max_immediate_iterations_per_frame: int = DEFAULT_MAX_IMMEDIATE_ITERATIONS_PER_FRAME</signature>
			<description>单帧最多连续执行的瞬时重复次数。小于 1 时按 1 处理。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</properties>
	<methods>
		<member kind="method" name="execute">
			<signature>func execute() -&gt; Variant:</signature>
			<description>启动重复执行流程。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">action_factory 有效时返回 repeat_completed Signal；无效时返回 null。</tag>
				<tag name="schema">return: Variant，返回 repeat_completed Signal 或 null。</tag>
			</tags>
		</member>
		<member kind="method" name="cancel">
			<signature>func cancel() -&gt; void:</signature>
			<description>取消重复流程并取消当前动作。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="pause">
			<signature>func pause() -&gt; void:</signature>
			<description>暂停重复流程和当前动作。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="resume">
			<signature>func resume() -&gt; void:</signature>
			<description>恢复重复流程和当前动作。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="finish">
			<signature>func finish() -&gt; void:</signature>
			<description>立即完成重复流程并释放等待者。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</methods>
	<innerClasses />
</class>
