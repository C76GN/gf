			<description>持续时间，单位秒。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="amplitude" decorators="@export_range(0.0, 1000.0, 0.001, &quot;or_greater&quot;)">
			<signature>var amplitude: float = 1.0</signature>
			<description>采样振幅倍率。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="frequency" decorators="@export_range(0.0, 240.0, 0.001, &quot;or_greater&quot;)">
			<signature>var frequency: float = 24.0</signature>
			<description>每秒采样频率。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="waveform" decorators="@export">
			<signature>var waveform: Waveform = Waveform.NOISE</signature>
			<description>波形类型。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="position_axis" decorators="@export">
			<signature>var position_axis: Vector3 = Vector3.ONE</signature>
			<description>位移轴权重。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="rotation_axis_degrees" decorators="@export">
			<signature>var rotation_axis_degrees: Vector3 = Vector3.ZERO</signature>
			<description>旋转轴权重，单位度。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="scale_axis" decorators="@export">
			<signature>var scale_axis: Vector3 = Vector3.ZERO</signature>
			<description>缩放偏移轴权重。返回值是叠加到基础 scale 上的偏移。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="decay_curve" decorators="@export">
			<signature>var decay_curve: Curve = null</signature>
			<description>包络曲线。为空时使用线性衰减；曲线值越高，当前采样越强。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="wave_curve" decorators="@export">
			<signature>var wave_curve: Curve = null</signature>
			<description>自定义波形曲线。仅在 waveform 为 CURVE 时使用，曲线值 0.5 表示零偏移。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="seed" decorators="@export">
			<signature>var seed: int = 1</signature>
			<description>确定性采样种子。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="tracks" decorators="@export">
			<signature>var tracks: Array[GFShakeTrack] = []</signature>
			<description>可组合反馈轨道。为空时使用兼容的单波形字段。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="schema">tracks: Array[GFShakeTrack]，按顺序采样并根据每个轨道 blend_mode 合成。</tag>
			</tags>
		</member>
