			<signature>func add_track(track: GFShakeTrack) -&gt; bool:</signature>
			<description>添加反馈轨道。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">track: 反馈轨道。</tag>
				<tag name="return">添加成功返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="clear_tracks">
			<signature>func clear_tracks() -&gt; void:</signature>
			<description>清空反馈轨道。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="has_tracks">
			<signature>func has_tracks() -&gt; bool:</signature>
			<description>检查是否存在有效轨道。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">存在有效轨道返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="zero_sample">
			<signature>static func zero_sample() -&gt; Dictionary:</signature>
			<description>创建空采样结果。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">空采样结果字典。</tag>
				<tag name="schema">return: Dictionary，包含零值 position、rotation_degrees、scale、intensity 与 progress。</tag>
			</tags>
		</member>
