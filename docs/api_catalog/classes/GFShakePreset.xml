		<member kind="method" name="sample">
			<signature>func sample(elapsed_seconds: float, strength: float = 1.0, phase_offset: float = 0.0) -&gt; Dictionary:</signature>
			<description>按时间采样反馈偏移。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">elapsed_seconds: 已经过的秒数。</tag>
				<tag name="param">strength: 本次播放强度倍率。</tag>
				<tag name="param">phase_offset: 相位偏移，用于同一预设多次播放时错开采样。</tag>
				<tag name="return">采样结果字典。</tag>
				<tag name="schema">return: Dictionary，包含 position: Vector3、rotation_degrees: Vector3、scale: Vector3、intensity: float 与 progress: float。</tag>
			</tags>
		</member>
		<member kind="method" name="sample_at_progress">
			<signature>func sample_at_progress( progress: float, elapsed_seconds: float, strength: float = 1.0, phase_offset: float = 0.0 ) -&gt; Dictionary:</signature>
			<description>按归一化进度采样反馈偏移。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">progress: 归一化进度，范围 0 到 1。</tag>
				<tag name="param">elapsed_seconds: 已经过的秒数。</tag>
				<tag name="param">strength: 本次播放强度倍率。</tag>
				<tag name="param">phase_offset: 相位偏移。</tag>
				<tag name="return">采样结果字典。</tag>
				<tag name="schema">return: Dictionary，包含 position: Vector3、rotation_degrees: Vector3、scale: Vector3、intensity: float 与 progress: float。</tag>
			</tags>
		</member>
