				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="current_position">
			<signature>var current_position: Vector2 = Vector2.ZERO</signature>
			<description>当前指针位置。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
