<?xml version="1.0" encoding="utf-8"?>
<class name="GFRefCountedPool" path="addons/gf/standard/utilities/pooling/gf_ref_counted_pool.gd" module="standard" extends="RefCounted" classDigest="8a251c472388a49e9515af32b0defbf032fec32fbd827c6eebe7e0f6509f6030">
	<description>GFRefCountedPool: 通用 RefCounted 对象池。
用工厂 Callable 创建短生命周期 RefCounted 对象，并在归还时通过 hook 或
reset_callback 显式清理状态。它不管理 Node、场景树、资源加载或业务生命周期。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">runtime_service</tag>
		<tag name="since">3.20.0</tag>
	</tags>
	<signals />
	<enums />
