			<signature>const HOOK_ON_ACQUIRE: StringName = &amp;"on_gf_pool_acquire"</signature>
			<description>对象可选实现：从池中取出后调用。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="const" name="HOOK_ON_RELEASE">
			<signature>const HOOK_ON_RELEASE: StringName = &amp;"on_gf_pool_release"</signature>
			<description>对象可选实现：归还池时调用。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="const" name="HOOK_RESET">
			<signature>const HOOK_RESET: StringName = &amp;"reset_for_pool"</signature>
			<description>对象可选实现：归还池时用于清理可复用状态。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</constants>
	<properties>
		<member kind="property" name="factory">
			<signature>var factory: Callable = Callable()</signature>
			<description>对象工厂。必须返回 RefCounted。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="reset_callback">
			<signature>var reset_callback: Callable = Callable()</signature>
			<description>归还对象时执行的可选重置回调。回调收到被归还的对象。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="max_available">
			<signature>var max_available: int:</signature>
			<description>最多保留的可用对象数量。为 0 时不限制。</description>
