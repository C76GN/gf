				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="created_count">
			<signature>var created_count: int:</signature>
			<description>池累计创建对象数量。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="available_count">
			<signature>var available_count: int:</signature>
			<description>当前可用对象数量。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="property" name="active_count">
			<signature>var active_count: int:</signature>
			<description>当前借出对象数量。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
	</properties>
	<methods>
		<member kind="method" name="configure">
			<signature>func configure( p_factory: Callable, p_reset_callback: Callable = Callable(), p_max_available: int = 0 ) -&gt; GFRefCountedPool:</signature>
			<description>配置对象池并返回自身。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">p_factory: 对象工厂，必须返回 RefCounted。</tag>
				<tag name="param">p_reset_callback: 归还对象时执行的可选重置回调。</tag>
				<tag name="param">p_max_available: 最多保留的可用对象数量；0 表示不限制。</tag>
				<tag name="return">当前对象池。</tag>
			</tags>
		</member>
		<member kind="method" name="acquire">
			<signature>func acquire() -&gt; RefCounted:</signature>
			<description>从池中借出对象。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">借出的 RefCounted；工厂无效或返回非 RefCounted 时返回 null。</tag>
			</tags>
		</member>
		<member kind="method" name="release">
			<signature>func release(item: RefCounted) -&gt; bool:</signature>
			<description>归还对象。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">item: 通过当前对象池借出的 RefCounted。</tag>
