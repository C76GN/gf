			</tags>
		</member>
		<member kind="method" name="prewarm">
			<signature>func prewarm(count: int) -&gt; int:</signature>
			<description>预热对象池。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">count: 要创建并保留的可用对象数量。</tag>
				<tag name="return">实际新增到可用池的数量。</tag>
			</tags>
		</member>
		<member kind="method" name="clear_available">
			<signature>func clear_available() -&gt; void:</signature>
			<description>清空当前可用对象，不影响已经借出的对象。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="reset_pool">
			<signature>func reset_pool() -&gt; void:</signature>
			<description>忘记借出记录并清空可用池。
这不会强制回收外部仍持有的 RefCounted，只让当前池停止追踪它们。</description>
			<tags>
				<tag name="api">public</tag>
			</tags>
		</member>
		<member kind="method" name="is_active">
			<signature>func is_active(item: RefCounted) -&gt; bool:</signature>
			<description>检查对象是否由当前池借出且尚未归还。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">item: 要检查的对象。</tag>
				<tag name="return">对象处于借出状态时返回 true。</tag>
			</tags>
		</member>
		<member kind="method" name="get_debug_snapshot">
			<signature>func get_debug_snapshot() -&gt; Dictionary:</signature>
			<description>获取对象池调试快照。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="return">调试快照。</tag>
				<tag name="schema">return: Dictionary，包含 created_count、available_count、active_count 与 max_available。</tag>
			</tags>
		</member>
