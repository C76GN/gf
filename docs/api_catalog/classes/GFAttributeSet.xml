<?xml version="1.0" encoding="utf-8"?>
<class name="GFAttributeSet" path="addons/gf/extensions/domain/attributes/gf_attribute_set.gd" module="extensions/domain" extends="Resource" classDigest="95c8c96bac71c5ae3644ca9f9bf67e2e561d33a19062b107479dd53942c5b942">
	<description>GFAttributeSet: 通用数值属性集合。
用 StringName 管理一组可保存、可恢复、可限制范围的数值属性。它不规定
属性含义，生命值、耐久、温度、声望或任意项目数值都由项目层命名和解释。</description>
	<tags>
		<tag name="api">public</tag>
		<tag name="category">domain_model</tag>
		<tag name="since">3.17.0</tag>
	</tags>
