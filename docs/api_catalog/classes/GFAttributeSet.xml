			<tags>
				<tag name="api">public</tag>
				<tag name="param">attribute_id: 发生变化的属性 ID。</tag>
				<tag name="param">current_value: 新当前值。</tag>
				<tag name="param">previous_value: 旧当前值。</tag>
			</tags>
		</member>
