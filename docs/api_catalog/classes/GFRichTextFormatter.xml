			<tags>
				<tag name="api">public</tag>
				<tag name="param">text: 输入文本。</tag>
				<tag name="return">可安全嵌入 BBCode 的文本。</tag>
			</tags>
		</member>
		<member kind="method" name="strip_bbcode">
			<signature>static func strip_bbcode(text: String) -&gt; String:</signature>
			<description>移除 BBCode 标签。</description>
			<tags>
				<tag name="api">public</tag>
				<tag name="param">text: 输入文本。</tag>
				<tag name="return">去掉标签后的文本。</tag>
			</tags>
		</member>
