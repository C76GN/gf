; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GF"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Gf="*uid://dftf1eh06apl0"

[editor_plugins]

enabled=PackedStringArray("res://addons/gf/plugin.cfg", "res://addons/gut/plugin.cfg")

[gf]

extensions/enabled=Array[String](["gf.action_queue", "gf.behavior_tree", "gf.capability", "gf.combat", "gf.domain", "gf.feedback", "gf.flow", "gf.interaction", "gf.network", "gf.physics", "gf.save", "gf.turn_based"])
extensions/export_fail_on_disabled_references=true
network/contract_paths=PackedStringArray()
network/contract_output_dir="res://gf/generated/network"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
